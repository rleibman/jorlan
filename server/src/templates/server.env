# Jorlan Server — environment variables
# Edit this file before starting the server for the first time.
# This file is sourced by the systemd unit (EnvironmentFile). Lines beginning with # are comments.
# (On macOS, ensure your service wrapper sources this file before launching the server.)
#
# After editing, restart the service:
#   sudo systemctl restart jorlan-server    (Linux)
#   brew services restart jorlan            (macOS)

# ── Database ──────────────────────────────────────────────────────────────────
# Run jorlan-init-db (or init-db.sh) once to create the database and user.
JORLAN_DB_URL=jdbc:mariadb://localhost:3306/jorlan
JORLAN_DB_USER=jorlan
JORLAN_DB_PASSWORD=changeme

# ── HTTP server ────────────────────────────────────────────────────────────────
JORLAN_HTTP_HOST=0.0.0.0
JORLAN_HTTP_PORT=8080

# ── Authentication ─────────────────────────────────────────────────────────────
# REQUIRED — JWT signing secret. Generate with: openssl rand -hex 32
JORLAN_AUTH_SECRET_KEY=replace-with-a-strong-random-secret

# ── AI / Model Gateway ─────────────────────────────────────────────────────────
JORLAN_AI_OLLAMA_BASE_URL=http://localhost:11434
JORLAN_AI_OLLAMA_MODEL=llama3.2:3b
