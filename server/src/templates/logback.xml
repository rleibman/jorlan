<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>/var/log/jorlan-server/server.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>/var/log/jorlan-server/server.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
      <maxHistory>30</maxHistory>
    </rollingPolicy>
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <appender name="CONVERSATION" class="ch.qos.logback.classic.sift.SiftingAppender">
    <discriminator>
      <key>sessionId</key>
      <defaultValue>unknown</defaultValue>
    </discriminator>
    <sift>
      <appender name="CONV-${sessionId}" class="ch.qos.logback.core.FileAppender">
        <file>/var/log/jorlan-server/conversations/session-${sessionId}.log</file>
        <append>true</append>
        <encoder>
          <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level %msg%n</pattern>
        </encoder>
      </appender>
    </sift>
  </appender>

  <logger name="com.zaxxer.hikari" level="WARN"/>
  <logger name="org.mariadb" level="WARN"/>
  <logger name="org.flywaydb" level="INFO"/>
  <logger name="io.getquill" level="WARN"/>
  <logger name="io.netty" level="WARN"/>
  <logger name="reactor" level="WARN"/>

  <logger name="jorlan" level="INFO"/>

  <logger name="jorlan.conversation" level="DEBUG" additivity="false">
    <appender-ref ref="CONVERSATION"/>
  </logger>

  <root level="INFO">
    <appender-ref ref="FILE"/>
  </root>

</configuration>
