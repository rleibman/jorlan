# Jorlan environment variables
# Copy to .env and fill in values. Never commit .env to source control.
#   cp .env.example .env && chmod 600 .env
# Source before starting the server:
#   source .env
#
# Variables marked REQUIRED have no built-in default. Jorlan will refuse to
# start if they are absent.

# ── Database ──────────────────────────────────────────────────────────────────
# Run server/src/main/scripts/init-db.sh once to create the database and user.
JORLAN_DB_URL=jdbc:mariadb://localhost:3306/jorlan
JORLAN_DB_USER=jorlan
JORLAN_DB_PASSWORD=changeme
# Optional overrides:
# JORLAN_DB_DRIVER=org.mariadb.jdbc.Driver
# JORLAN_DB_MAX_POOL_SIZE=10
# JORLAN_DB_MIN_IDLE=2
# JORLAN_DB_CONNECTION_TIMEOUT_MILLIS=30000
# JORLAN_DB_IDLE_TIMEOUT_MILLIS=600000
# JORLAN_DB_KEEPALIVE_TIME_MILLIS=300000

# ── Flyway ─────────────────────────────────────────────────────────────────────
# JORLAN_FLYWAY_ENABLED=true
# JORLAN_FLYWAY_TARGET=     # Migrate only up to this version (empty = latest)

# ── HTTP server ────────────────────────────────────────────────────────────────
JORLAN_HTTP_HOST=0.0.0.0
JORLAN_HTTP_PORT=8080

# ── Web frontend ───────────────────────────────────────────────────────────────
# Path to the built Scala.js SPA. Default in dev is "debugDist" (sbt debugDist).
# For production set this to the directory produced by sbt dist.
JORLAN_WEB_ROOT=/opt/jorlan/www

# ── Authentication ─────────────────────────────────────────────────────────────
# REQUIRED — JWT signing secret. Generate a strong value with:
#   openssl rand -hex 32
JORLAN_AUTH_SECRET_KEY=replace-with-a-strong-random-secret

# Optional session TTL overrides:
# JORLAN_AUTH_ACCESS_TTL_MINUTES=60
# JORLAN_AUTH_REFRESH_TTL_DAYS=30

# ── OAuth providers (all optional — omit to disable) ───────────────────────────
# Google OAuth:
# JORLAN_GOOGLE_CLIENT_ID=
# JORLAN_GOOGLE_CLIENT_SECRET=

# GitHub OAuth:
# JORLAN_GITHUB_CLIENT_ID=
# JORLAN_GITHUB_CLIENT_SECRET=

# Discord OAuth:
# JORLAN_DISCORD_CLIENT_ID=
# JORLAN_DISCORD_CLIENT_SECRET=

# ── AI / Model Gateway ─────────────────────────────────────────────────────────
# Ollama base URL and default model:
# JORLAN_AI_OLLAMA_BASE_URL=http://localhost:11434
# JORLAN_AI_OLLAMA_MODEL=llama3.2:3b

# Qdrant vector store (used by Phase 9+ memory system):
# JORLAN_AI_QDRANT_HOST=localhost
# JORLAN_AI_QDRANT_RPC_PORT=6334

# ── Market Data (Alpha Vantage) ────────────────────────────────────────────────
# Optional — obtain a free API key at https://www.alphavantage.co/support/#api-key
# Without this key the market.* tools return an error without making any HTTP call.
# JORLAN_ALPHA_VANTAGE_API_KEY=
